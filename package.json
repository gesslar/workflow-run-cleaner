{
  "name": "workflow-run-cleaner",
  "version": "1.9.2",
  "description": "Clean up old workflow runs",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "version": "npm run build && git add dist",
    "update": "npx npm-check-updates -u && npm install",
    "lint": "eslint src/",
    "go": "gh pr create --fill && gh pr -mrd --auto",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "keywords": [
    "github",
    "action",
    "workflows",
    "automation"
  ],
  "author": "gesslar",
  "license": "0BSD",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.4.1",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.5.0"
  }
}
